# Headroom API - C1 environment template
PORT=4010
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/headroom
SELLER_SECRET_ENC_KEY_B64=<base64-32-byte-key>
UPSTREAM_TIMEOUT_MS=120000
ANTHROPIC_UPSTREAM_BASE_URL=https://api.anthropic.com
KEY_HEALTHCHECK_ENABLED=true
KEY_HEALTHCHECK_MAX_KEYS=20
KEY_HEALTHCHECK_TIMEOUT_MS=5000
KEY_HEALTHCHECK_QUARANTINE_THRESHOLD=3

# Token-mode pilot gates
# Comma-separated org UUID allowlist for token-mode routing
TOKEN_MODE_ENABLED_ORGS=
# Optional refresh endpoint used when upstream returns 401/403
TOKEN_REFRESH_ENDPOINT=
